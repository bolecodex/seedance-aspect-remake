# 火山方舟 API Key
ARK_API_KEY=

# 可选：火山方舟 Base URL 与 Seedance 模型
ARK_BASE_URL=https://ark.cn-beijing.volces.com
SEEDANCE_MODEL=doubao-seedance-2-0-260128
SEEDANCE_RESOLUTION=720p

# 可选：终端用户安全标识，不要填写明文手机号/邮箱，建议用哈希后的用户 ID
# SEEDANCE_SAFETY_IDENTIFIER=

# 可选：轮询与超时
SEEDANCE_REQUEST_TIMEOUT=120
SEEDANCE_POLL_INTERVAL=10
SEEDANCE_POLL_MAX_WAIT=1800

# TOS 上传配置。视频参考模式需要公网可访问的 TOS URL
VOLC_ACCESSKEY=
VOLC_SECRETKEY=
TOS_BUCKET=
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_REGION=cn-beijing
TOS_SIGNED_URL_EXPIRES=604800
